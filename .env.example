# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================

# ---- Application ----
APP_NAME="RetailIQ — Demand Forecasting"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | production | testing
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=false

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Database ----
# SQLite (development):
DATABASE_URL=sqlite:///./retailiq.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/retailiq_db

POSTGRES_USER=retailiq
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=retailiq_db

# ---- Security ----
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ---- Feature Engineering ----
LAG_PERIODS=1,7,14,30
ROLLING_WINDOWS=7,14,30
TRAIN_FRAC=0.70
VAL_FRAC=0.15
TEST_FRAC=0.15

# ---- Deep Learning ----
DL_LOOKBACK=60
DL_EPOCHS=100
DL_BATCH_SIZE=32
DL_DROPOUT=0.2
LSTM_UNITS=64
GRU_UNITS=64

# ---- Model Cache ----
MODEL_CACHE_TTL_SECONDS=3600

# ---- Paths (relative to project root) ----
DATASETS_DIR=datasets
SAVED_MODELS_DIR=saved_models
LOGS_DIR=logs
REPORTS_DIR=reports
